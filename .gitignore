.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
*.swp
*~

# ── OS cruft ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs / temp ───────────────────────────────────────────────
*.log
hs_err_pid*
